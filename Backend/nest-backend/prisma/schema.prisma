generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  phone              String    @unique
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               String    @default("") @db.VarChar(20)
  fullName           String    @map("full_name")
  avatarUrl          String    @default("") @map("avatar_url")
  language           String    @default("uz")
  isVerified         Boolean   @default(false) @map("is_verified")
  emailVerified      Boolean   @default(false) @map("email_verified")
  emailOtpCode       String    @default("") @map("email_otp_code")
  emailOtpExpiresAt  DateTime? @map("email_otp_expires_at")
  emailOtpLastSentAt DateTime? @map("email_otp_last_sent_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  shop          ShopProfile?
  vehicles      Vehicle[]      @relation("VehicleOwner")
  bookings      Booking[]      @relation("BookingCustomer")
  reviews       Review[]       @relation("ReviewAuthor")
  notifications Notification[] @relation("UserNotifications")
  fcmTokens     FCMToken[]     @relation("UserFCMTokens")
  customerCards CustomerCard[] @relation("CustomerCardUser")

  @@map("users")
}

model ShopProfile {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  shopName           String   @default("") @map("shop_name")
  address            String   @default("")
  latitude           Float    @default(0)
  longitude          Float    @default(0)
  phone              String   @default("")
  workingHours       String   @default("") @map("working_hours")
  serviceTypes       String[] @map("service_types")
  verificationStatus String   @default("pending") @map("verification_status") @db.VarChar(20)
  verificationNotes  String   @default("") @map("verification_notes")
  ratingAvg          Float    @default(0) @map("rating_avg")
  ratingCount        Int      @default(0) @map("rating_count")
  totalBookings      Int      @default(0) @map("total_bookings")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  bookings      Booking[]      @relation("BookingShop")
  customerCards CustomerCard[] @relation("CustomerCardShop")

  @@map("shop_profiles")
}

model Vehicle {
  id        String   @id @default(uuid()) @db.Uuid
  plate     String   @unique
  ownerId   String   @map("owner_id") @db.Uuid
  make      String   @default("")
  model     String   @default("")
  year      Int      @default(0)
  color     String   @default("")
  photoUrl  String   @default("") @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner    User      @relation("VehicleOwner", fields: [ownerId], references: [id])
  bookings Booking[] @relation("BookingVehicle")

  @@map("vehicles")
}

model ServiceType {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  nameUz    String   @map("name_uz")
  nameRu    String   @map("name_ru")
  icon      String   @default("")
  basePrice Int      @default(0) @map("base_price")
  isActive  Boolean  @default(true) @map("is_active")

  bookings Booking[] @relation("BookingServiceType")

  @@map("service_types")
}

model Booking {
  id            String    @id @default(uuid()) @db.Uuid
  customerId    String    @map("customer_id") @db.Uuid
  shopId        String    @map("shop_id") @db.Uuid
  vehicleId     String    @map("vehicle_id") @db.Uuid
  serviceTypeId String    @map("service_type_id") @db.Uuid
  scheduledAt   DateTime  @map("scheduled_at")
  notes         String    @default("")
  status        String    @default("pending") @db.VarChar(30)
  totalPrice    Int       @default(0) @map("total_price")
  cancelReason  String    @default("") @map("cancel_reason")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  customer    User        @relation("BookingCustomer", fields: [customerId], references: [id])
  shop        ShopProfile @relation("BookingShop", fields: [shopId], references: [id])
  vehicle     Vehicle     @relation("BookingVehicle", fields: [vehicleId], references: [id])
  serviceType ServiceType @relation("BookingServiceType", fields: [serviceTypeId], references: [id])
  payment     Payment?    @relation("BookingPayment")
  tips        Tip[]       @relation("BookingTips")
  reviews     Review[]    @relation("BookingReviews")

  @@map("bookings")
}

model Payment {
  id        String    @id @default(uuid()) @db.Uuid
  bookingId String    @unique @map("booking_id") @db.Uuid
  amount    Int       @default(0)
  method    String    @default("") @db.VarChar(30)
  status    String    @default("pending") @db.VarChar(20)
  qrCode    String    @default("") @map("qr_code")
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")

  booking Booking @relation("BookingPayment", fields: [bookingId], references: [id])

  @@map("payments")
}

model Tip {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  amount    Int
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation("BookingTips", fields: [bookingId], references: [id])

  @@map("tips")
}

model CustomerCard {
  id          String    @id @default(uuid()) @db.Uuid
  shopId      String    @map("shop_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  isVip       Boolean   @default(false) @map("is_vip")
  notes       String    @default("")
  visitCount  Int       @default(0) @map("visit_count")
  lastVisitAt DateTime? @map("last_visit_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  shop     ShopProfile @relation("CustomerCardShop", fields: [shopId], references: [id])
  customer User        @relation("CustomerCardUser", fields: [customerId], references: [id])

  @@unique([shopId, customerId])
  @@map("customer_cards")
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  bookingId   String   @map("booking_id") @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  targetId    String   @map("target_id") @db.Uuid
  reviewType  String   @map("review_type") @db.VarChar(20)
  rating      Int
  comment     String   @default("")
  isModerated Boolean  @default(false) @map("is_moderated")
  createdAt   DateTime @default(now()) @map("created_at")

  booking Booking @relation("BookingReviews", fields: [bookingId], references: [id])
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id])

  @@unique([bookingId, reviewType])
  @@map("reviews")
}

model SeasonalRule {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  sendMonth  Int       @map("send_month")
  sendDay    Int       @map("send_day")
  messageUz  String    @map("message_uz")
  messageRu  String    @map("message_ru")
  isActive   Boolean   @default(true) @map("is_active")
  lastSentAt DateTime? @map("last_sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("seasonal_rules")
}

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  body        String
  type        String   @default("")
  referenceId String   @default("") @map("reference_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation("UserNotifications", fields: [userId], references: [id])

  @@map("notifications")
}

model FCMToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String
  platform  String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserFCMTokens", fields: [userId], references: [id])

  @@map("fcm_tokens")
}
