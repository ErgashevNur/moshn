# ============================================================
# Moshn — Docker Compose muhit o'zgaruvchilari
# Nusxa oling:  cp .env.example .env  va qiymatlarni to'ldiring.
# ============================================================

# --- Database (docker postgres) ---
DB_NAME=moshn
DB_USER=moshn
DB_PASSWORD=change_this_strong_password

# --- JWT (uzun tasodifiy satr) ---
JWT_SECRET=change_this_to_a_long_random_string

# --- Claude API (Anthropic) — OCR va voice parsing ---
CLAUDE_API_KEY=sk-ant-...

# --- UzbekVoice STT ---
UZBEKVOICE_API_KEY=

# --- Firebase Cloud Messaging (push) ---
FCM_SERVER_KEY=

# --- Yandex Maps ---
YANDEX_MAPS_API_KEY=

# --- Email (Gmail SMTP App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=Moshn <your.email@gmail.com>

# --- CORS: admin/sayt origin(lar)i, vergul bilan ---
ALLOWED_ORIGINS=https://moshn.uz,https://www.moshn.uz

# --- Admin panel build-time API URL ---
# API alohida subdomenda (api.moshn.uz):
NEXT_PUBLIC_API_URL=https://api.moshn.uz/v1
